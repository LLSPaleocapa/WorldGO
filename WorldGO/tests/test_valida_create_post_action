<?php

use PHPUnit\Framework\TestCase;

require_once __DIR__ . '/../src/PostValidator.php';

class PostValidatorTest extends TestCase {

    public function testPostValido() {

        $result = validatePost(
            "Titolo",
            "Descrizione"
        );

        $this->assertTrue($result);
    }

    public function testTitoloVuoto() {

        $this->expectException(Exception::class);

        validatePost(
            "",
            "Descrizione"
        );
    }
}